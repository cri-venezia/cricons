{
  "name": "cricons",
  "version": "1.0.0",
  "description": "SVG icon library for Vue.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/cricons.umd.js",
  "module": "./dist/cricons.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cricons.es.js",
      "require": "./dist/cricons.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "generate": "tsx scripts/generate-icons.ts",
    "build": "npm run generate && vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write ."
  },
  "keywords": [
    "vue",
    "svg",
    "icons"
  ],
  "author": "Luca Forzutti",
  "license": "ISC",
  "dependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.22.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.3",
    "prettier": "^3.2.5",
    "scule": "^1.3.0",
    "svgo": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.0"
  }
}
