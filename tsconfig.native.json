{
    "compilerOptions": {
        "outDir": "dist/native",
        "declaration": true,
        "jsx": "react",
        "module": "esnext",
        "target": "esnext",
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "strict": true
    },
    "include": [
        "src/native/**/*"
    ]
}